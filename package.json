{
  "name": "@brianmwirigi/aux-mcp",
  "version": "0.4.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "AUX — Spotify for your AI. Vibe DJ, roast cards, battles, party rooms, auto-DJ. Full Spotify MCP.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "aux-mcp": "dist/server.js"
  },
  "main": "dist/server.js",
  "files": [
    "dist",
    "web",
    "docs",
    "README.md",
    "LICENSE",
    ".env.example",
    "examples"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "login": "tsx src/login.ts",
    "status": "tsx src/server.ts status",
    "autodj": "tsx src/server.ts autodj",
    "party-host": "tsx src/server.ts party-host",
    "web": "tsx src/server.ts web",
    "demo": "tsx src/server.ts demo",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brian-mwirigi/aux-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/brian-mwirigi/aux-mcp/issues"
  },
  "homepage": "https://github.com/brian-mwirigi/aux-mcp#readme",
  "keywords": [
    "spotify",
    "mcp",
    "model-context-protocol",
    "music",
    "claude",
    "cursor",
    "cline",
    "aux",
    "dj"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "open": "^10.1.0",
    "pkce-challenge": "^4.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
